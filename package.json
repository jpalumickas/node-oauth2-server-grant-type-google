{
  "name": "oauth2-server-grant-type-google",
  "version": "0.7.0",
  "description": "Google grant type for @node-oauth/oauth2-server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpalumickas/node-oauth2-server-grant-type-google.git"
  },
  "homepage": "https://github.com/jpalumickas/node-oauth2-server-grant-type-google#readme",
  "bugs": {
    "url": "https://github.com/jpalumickas/node-oauth2-server-grant-type-google/issues"
  },
  "author": {
    "name": "Justas Palumickas",
    "email": "jpalumickas@gmail.com",
    "url": "https://jpalumickas.com"
  },
  "license": "MIT",
  "peerDependencies": {
    "@node-oauth/oauth2-server": "^5.0.0"
  },
  "devDependencies": {
    "@node-oauth/oauth2-server": "^5.3.0",
    "@types/node": "^25.8.0",
    "oxfmt": "^0.50.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "oauth",
    "oauth2",
    "oauth2-server",
    "grant-type",
    "google"
  ],
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
